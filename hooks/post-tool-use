#!/usr/bin/env bash
# PostToolUse hook for supertester plugin
# After Write/Edit: remind to update progress.md and phase output files

set -euo pipefail

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context=""

if [ -d ".supertester" ]; then
    context="<POST-TOOL-REMINDER>\\nYou just wrote/edited a file. Remember to:\\n1. Update progress.md with what you just did\\n2. Update the corresponding phase output file\\n3. Follow the 2-Action Rule: if you've done 2+ operations, update findings.md now\\n</POST-TOOL-REMINDER>"
fi

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PostToolUse",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$context"
fi

exit 0
