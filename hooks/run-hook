#!/usr/bin/env bash
# Cross-platform shell wrapper for Codex plugin hooks.

set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "run-hook: missing script name" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_NAME="$1"
shift || true

exec bash "${SCRIPT_DIR}/${SCRIPT_NAME}" "$@"
